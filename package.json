{
  "name": "inkora",
  "version": "0.1.0",
  "private": true,
  "description": "inkora — Print. Gift. Belong. The craft house for modern offices.",
  "engines": {
    "node": ">=22.13.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.1.2",
  "scripts": {
    "dev": "pnpm --filter @inkora/web dev",
    "dev:studio": "pnpm --filter @inkora/studio dev",
    "dev:all": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "clean": "pnpm -r exec rm -rf node_modules .next dist build && rm -rf node_modules"
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.6"
  }
}

# =================================================================
# inkora — Environment Variables Template
# =================================================================
# Copy this file to .env.local in each app that needs it.
# NEVER commit .env files with real secrets.
# =================================================================


# -----------------------------------------------------------------
# 0. BRAND (used by all apps — drives display name, URLs, copy)
# -----------------------------------------------------------------
# To rebrand later, change these and the entire app updates.
# (The codebase reads from packages/brand by default; env can override.)
NEXT_PUBLIC_BRAND_NAME=inkora
NEXT_PUBLIC_BRAND_TAGLINE=Print. Gift. Belong.
NEXT_PUBLIC_BRAND_DESCRIPTION=The craft house for modern offices.
NEXT_PUBLIC_SITE_URL=https://inkora.com


# -----------------------------------------------------------------
# 1. CONTACT — drives WhatsApp widget, click-to-call, footer
# -----------------------------------------------------------------
# WhatsApp number in international format WITHOUT +, e.g. 919876543210
NEXT_PUBLIC_WHATSAPP_NUMBER=919876543210
NEXT_PUBLIC_PHONE_NUMBER=+91 98765 43210
NEXT_PUBLIC_CONTACT_EMAIL=hello@inkora.com
NEXT_PUBLIC_SUPPORT_EMAIL=support@inkora.com


# -----------------------------------------------------------------
# 2. SANITY CMS (content: products, collections, articles)
# -----------------------------------------------------------------
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01
# Server-only token for write operations / draft preview
SANITY_API_READ_TOKEN=
SANITY_REVALIDATE_SECRET=


# -----------------------------------------------------------------
# 3. SUPABASE (transactional DB: orders, customers, carts)
# -----------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only — bypasses Row Level Security. KEEP SECRET.
SUPABASE_SERVICE_ROLE_KEY=


# -----------------------------------------------------------------
# 4. RAZORPAY (payments)
# -----------------------------------------------------------------
# Public key id — safe to expose in the browser
NEXT_PUBLIC_RAZORPAY_KEY_ID=
# Server-only — used to create orders and verify signatures
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=


# -----------------------------------------------------------------
# 5. RESEND (transactional email)
# -----------------------------------------------------------------
RESEND_API_KEY=
RESEND_FROM_EMAIL=orders@inkora.com
RESEND_FROM_NAME=inkora


# -----------------------------------------------------------------
# 6. ANALYTICS & MONITORING (optional)
# -----------------------------------------------------------------
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=


# -----------------------------------------------------------------
# 7. ADMIN
# -----------------------------------------------------------------
# Comma-separated emails that receive new-order notifications
ADMIN_NOTIFICATION_EMAILS=
